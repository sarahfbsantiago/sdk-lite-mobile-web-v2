{
  "name": "yuno-integration",
  "version": "2.0.0",
  "description": "Yuno Payment Gateway Integration - Web + Mobile (supports multiple SDK types: Lite, Full, Seamless, Headless)",
  "private": true,
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "npm test -- tests/unit",
    "test:integration": "npm test -- tests/integration",
    "test:coverage": "npm test -- --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "yuno",
    "payment",
    "sdk",
    "checkout"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jest": "^29.7.0"
  }
}
