# ===========================================
# Configuracoes do Servidor
# ===========================================
NODE_ENV=development
PORT=8082
HOST=0.0.0.0
BASE_URL=http://localhost:8082

# ===========================================
# Yuno API - Credenciais
# ===========================================
# Obtenha suas credenciais em: https://dashboard.y.uno
API_URL=https://api-sandbox.y.uno
PUBLIC_API_KEY=your_public_api_key_here
PRIVATE_SECRET_KEY=your_private_secret_key_here
ACCOUNT_CODE=your_account_code_here
CUSTOMER_ID=your_customer_id_here

# ===========================================
# Webhook
# ===========================================
# Secret para validar assinatura do webhook (opcional)
WEBHOOK_SECRET=

# ===========================================
# Logging
# ===========================================
# Niveis: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
